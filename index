        }

        .btn:hover {
            transform: scale(1.03);
            box-shadow: 0 0 30px rgba(0, 255, 102, 0.6);
        }

        footer {
            text-align: center;
            color: #555;
            font-size: 0.8rem;
            margin-top: 60px;
            padding-top: 20px;
            border-top: 1px solid #222;
